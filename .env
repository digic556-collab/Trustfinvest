# Environment variables for TrustFinvest Backend

# Server Configuration
NODE_ENV=development
PORT=5000

# Firebase Configuration
# Note: The service account is handled by firebase-admin.js
FIREBASE_PROJECT_ID=trustfin-8e4d1
FIREBASE_STORAGE_BUCKET=trustfin-8e4d1.appspot.com

# SMTP Configuration for Nodemailer (replace with your SMTP provider's details)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@trustfinvest.com
SMTP_PASSWORD=Beesystem1#
SMTP_FROM_NAME="TrustFinvest"
SMTP_FROM_EMAIL=info@trustfinvest.com

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Enable Logs
ENABLE_EMAIL_LOGS=true
