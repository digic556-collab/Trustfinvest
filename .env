# SMTP Configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@trustfinvest.com
SMTP_PASSWORD=Beesystem1#
SMTP_FROM_NAME=TrustFinvest
SMTP_FROM_EMAIL=info@trustfinvest.com

# API Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=*

# Database Configuration (Optional - for future use)
MONGODB_URI=mongodb://localhost:27017/trustfinvest

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Email Configuration
EMAIL_FROM=info@trustfinvest.com
EMAIL_ADMIN=admin@trustfinvest.com
ENABLE_EMAIL_LOGS=true
